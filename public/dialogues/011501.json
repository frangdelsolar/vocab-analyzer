{
    "lesson_number": 15,
    "dialogue_id": "15-01",
    "title": "我不舒服",
    "participants": ["醫生 (Yīshēng)", "如玉 (Rúyù)"],
    "content": [
        {
            "speaker": "醫生",
            "text": "白小姐，妳哪裡不舒服？"
        },
        {
            "speaker": "如玉",
            "text": "我一直流鼻水，頭很痛，胃口很差。什麼東西都不想吃。"
        },
        {
            "speaker": "醫生",
            "text": "大概多久了？"
        },
        {
            "speaker": "如玉",
            "text": "已經四、五天了。"
        },
        {
            "speaker": "醫生",
            "text": "我看看妳的喉嚨。喉嚨有一點發炎。"
        },
        {
            "speaker": "如玉",
            "text": "請問我生的是什麼病？"
        },
        {
            "speaker": "醫生",
            "text": "妳有一點發燒，是感冒，不過沒有什麼關係。"
        },
        {
            "speaker": "如玉",
            "text": "請問我得吃藥嗎？"
        },
        {
            "speaker": "醫生",
            "text": "要，妳到藥局去拿藥。"
        },
        {
            "speaker": "如玉",
            "text": "好的。請問我的病什麼時候會好？"
        },
        {
            "speaker": "醫生",
            "text": "回去把藥吃了，多喝水，多休息，早一點睡覺，很快就會好。"
        },
        {
            "speaker": "如玉",
            "text": "好的，謝謝您。"
        }
    ]
}
