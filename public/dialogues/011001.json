{
    "dialogue_id": "10-01",
    "title": "臺灣水果真好吃",
    "participants": ["如玉", "月美"],
    "video_url": "https://www.youtube.com/watch?v=jEWdhn2SHic&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=38",
    "vocabulary_video_url": "https://www.youtube.com/watch?v=0wndmfJFDtE&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=39",
    "content": [
        {
            "speaker": "如玉",
            "text": "這個黃色的水果叫什麼？"
        },
        {
            "speaker": "月美",
            "text": "芒果。給妳一塊，吃吃看。"
        },
        {
            "speaker": "如玉",
            "text": "好，謝謝。[taking a bite] 香香的、甜甜的，很好吃。"
        },
        {
            "speaker": "月美",
            "text": "昨天明華給我們的那種水果，紅色的，叫什麼？"
        },
        {
            "speaker": "如玉",
            "text": "妳說的是西瓜吧？"
        },
        {
            "speaker": "月美",
            "text": "對！對！對！臺灣有很多好吃的水果。"
        },
        {
            "speaker": "如玉",
            "text": "我以前不喜歡吃水果，現在很喜歡了。"
        },
        {
            "speaker": "月美",
            "text": "越南的水果也很好吃。"
        },
        {
            "speaker": "如玉",
            "text": "要是有機會，我想吃吃看。"
        },
        {
            "speaker": "月美",
            "text": "妳來越南，我一定請妳吃。"
        }
    ],
    "lesson_number": 10
}
