{
    "dialogue_id": "08-01",
    "title": "坐高鐵比坐火車快",
    "participants": ["如玉", "明華"],
    "video_url": "https://www.youtube.com/watch?v=y6ZAiO3VsAM&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=20",
    "vocabulary_video_url": "https://www.youtube.com/watch?v=A1BKs7o5Aag&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=21",
    "content": [
        {
            "speaker": "如玉",
            "text": "這個週末，我想跟朋友去臺南玩。"
        },
        {
            "speaker": "明華",
            "text": "怎麼去？"
        },
        {
            "speaker": "如玉",
            "text": "我想坐火車去。"
        },
        {
            "speaker": "明華",
            "text": "火車太慢了，要四個多鐘頭，坐高鐵比較快。"
        },
        {
            "speaker": "如玉",
            "text": "可是聽說高鐵車票非常貴。"
        },
        {
            "speaker": "明華",
            "text": "高鐵車票有一點貴，但是坐高鐵又快又舒服。"
        },
        {
            "speaker": "如玉",
            "text": "我不知道在哪裡買票。"
        },
        {
            "speaker": "明華",
            "text": "在高鐵站、網路上或是便利商店都可以。"
        },
        {
            "speaker": "如玉",
            "text": "這麼方便！那我坐高鐵去，謝謝你。"
        }
    ],
    "lesson_number": 8
}
