{
    "dialogue_id": "12-01",
    "title": "打算學多久中文？",
    "participants": ["田中", "安同"],
    "video_url": "https://www.youtube.com/watch?v=m2q2LT85Flg&list=PLzhEEEIeppr9DGKlQJeZglps1ubDHUE0x&index=11",
    "vocabulary_video_url": "https://www.youtube.com/watch?v=ude3YPmDHEA&list=PLzhEEEIeppr9DGKlQJeZglps1ubDHUE0x&index=12",
    "content": [
        {
            "speaker": "田中",
            "text": "安同，你計畫在臺灣學多久的中文？"
        },
        {
            "speaker": "安同",
            "text": "五年。"
        },
        {
            "speaker": "田中",
            "text": "為什麼要這麼久的時間？"
        },
        {
            "speaker": "安同",
            "text": "我先在語言中心念一年，再念四年大學，所以需要五年。"
        },
        {
            "speaker": "田中",
            "text": "這得花不少錢！"
        },
        {
            "speaker": "安同",
            "text": "對，不過我有獎學金。要是成績不好，就沒獎學金了。你呢？"
        },
        {
            "speaker": "田中",
            "text": "我的學費是公司替我付的。"
        },
        {
            "speaker": "安同",
            "text": "你打算學多久呢？"
        },
        {
            "speaker": "田中",
            "text": "大概兩年，是公司決定的。"
        },
        {
            "speaker": "安同",
            "text": "希望我以後也可以到這麼好的公司上班。"
        },
        {
            "speaker": "田中",
            "text": "我又要上班，又要念書，真的很累。"
        },
        {
            "speaker": "安同",
            "text": "我們一起加油吧！"
        }
    ],
    "lesson_number": 12
}
