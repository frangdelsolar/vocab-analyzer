{
    "dialogue_id": "09-01",
    "title": "要去玩幾天？",
    "participants": ["安同", "田中"],
    "video_url": "https://www.youtube.com/watch?v=_EW9tJvoGqg&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=29",
    "vocabulary_video_url": "https://www.youtube.com/watch?v=NOH9h-ENOnc&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=30",
    "content": [
        {
            "speaker": "安同",
            "text": "田中，下個星期我們放五天的假，你要回國嗎？"
        },
        {
            "speaker": "田中",
            "text": "不，我打算在家看電視、影片學中文，你呢？"
        },
        {
            "speaker": "安同",
            "text": "我想跟朋友去玩。"
        },
        {
            "speaker": "田中",
            "text": "不錯啊。去什麼地方？"
        },
        {
            "speaker": "安同",
            "text": "臺東。聽說那裡的風景非常漂亮。"
        },
        {
            "speaker": "田中",
            "text": "我也聽說。放假的時候，你常去旅行嗎？"
        },
        {
            "speaker": "安同",
            "text": "不一定。有時候在家寫功課，有時候出去玩。"
        },
        {
            "speaker": "田中",
            "text": "你們什麼時候去臺東？"
        },
        {
            "speaker": "安同",
            "text": "這個星期六下午去。"
        },
        {
            "speaker": "田中",
            "text": "去玩多久？"
        },
        {
            "speaker": "安同",
            "text": "大概玩四、五天。"
        }
    ],
    "lesson_number": 9
}
