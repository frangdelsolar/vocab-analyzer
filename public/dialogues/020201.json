{
    "dialogue_id": "02-01",
    "title": "還是坐捷運吧！",
    "participants": [
        "如玉",
        "安同"
    ],
    "video_url": "",
    "vocabulary_video_url": "",
    "content": [
        {
            "speaker": "如玉",
            "text": "安同，早！你要去哪裡？"
        },
        {
            "speaker": "安同",
            "text": "早！我約了朋友一起去看電影，你呢？"
        },
        {
            "speaker": "如玉",
            "text": "我要去看電腦展。"
        },
        {
            "speaker": "安同",
            "text": "你去哪裡看電腦展？"
        },
        {
            "speaker": "如玉",
            "text": "世貿展覽館，我現在要去對面坐公車。"
        },
        {
            "speaker": "安同",
            "text": "那裡離台北 101 不遠，妳怎麼不坐捷運呢？"
        },
        {
            "speaker": "如玉",
            "text": "朋友告訴我公車直接到展覽館，不必換車。"
        },
        {
            "speaker": "安同",
            "text": "坐捷運也很方便。妳先坐 2 號線到台北車站，再換車到展覽館。"
        },
        {
            "speaker": "如玉",
            "text": "聽起來坐捷運比較麻煩。"
        },
        {
            "speaker": "安同",
            "text": "一點也不麻煩，捷運比較快，坐公車要花一個多小時。你還是坐捷運吧！"
        },
        {
            "speaker": "如玉",
            "text": "捷運站遠嗎？"
        },
        {
            "speaker": "安同",
            "text": "捷運站就在前面。"
        },
        {
            "speaker": "如玉",
            "text": "謝謝！我得趕快走了。"
        },
        {
            "speaker": "安同",
            "text": "別急，走慢一點。捷運的班次很多。"
        },
        {
            "speaker": "如玉",
            "text": "好，我們下禮拜見。"
        }
    ],
    "lesson_number": 2
}