{
    "lesson_number": 7,
    "dialogue_id": "07-02",
    "title": "要去哪裡？",
    "participants": ["安同 (Āntóng)", "如玉 (Rúyù)"],
    "content": [
        {
            "speaker": "安同",
            "text": "如玉，妳在吃飯啊？"
        },
        {
            "speaker": "如玉",
            "text": "是，吃午餐，等一下要上課。你呢？"
        },
        {
            "speaker": "安同",
            "text": "我剛下課。對了，下午四點半學校有籃球比賽。妳想去看嗎？"
        },
        {
            "speaker": "如玉",
            "text": "想啊。比賽幾點結束？"
        },
        {
            "speaker": "安同",
            "text": "六點半。妳晚上有事嗎？"
        },
        {
            "speaker": "如玉",
            "text": "我最近很忙，每天晚上都上書法課。"
        },
        {
            "speaker": "安同",
            "text": "學得怎麼樣？"
        },
        {
            "speaker": "如玉",
            "text": "剛開始學，字寫得不好，可是我覺得很有意思。"
        },
        {
            "speaker": "安同",
            "text": "我有空可以去看看嗎？"
        },
        {
            "speaker": "如玉",
            "text": "我得問問老師。"
        }
    ]
}
