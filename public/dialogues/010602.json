{
    "dialogue_id": "06-02",
    "title": "她們學校在山上",
    "participants": ["怡君", "安同", "如玉"],
    "video_url": "https://www.youtube.com/watch?v=P5G_7e5ZNsE&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=4",
    "vocabulary_video_url": "https://www.youtube.com/watch?v=CnERwdaEX00&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=5",
    "content": [
        {
            "speaker": "怡君",
            "text": "歡迎你們來。"
        },
        {
            "speaker": "安同",
            "text": "你們學校真遠！"
        },
        {
            "speaker": "怡君",
            "text": "是啊，不是很近，有一點不方便。"
        },
        {
            "speaker": "如玉",
            "text": "這裡的學生在哪裡買東西？"
        },
        {
            "speaker": "怡君",
            "text": "在學校外面。學校裡面沒有商店。"
        },
        {
            "speaker": "安同",
            "text": "吃飯呢？學校裡面有沒有餐廳？"
        },
        {
            "speaker": "怡君",
            "text": "有，餐廳在學生宿舍的一樓。"
        },
        {
            "speaker": "安同",
            "text": "前面這棟大樓很漂亮。"
        },
        {
            "speaker": "怡君",
            "text": "這是圖書館，旁邊的那棟大樓是教室，圖書館後面有游泳池。"
        }
    ],
    "lesson_number": 6
}
