{
    "dialogue_id": "08-02",
    "title": "坐高鐵比坐火車快",
    "participants": ["如玉", "安同"],
    "video_url": "https://www.youtube.com/watch?v=u3zj8ULa6wU&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=22",
    "vocabulary_video_url": "https://www.youtube.com/watch?v=FpVNUkkc8_w&list=PLzhEEEIeppr8eIolQjg2scNnytVQ1vm46&index=23",
    "content": [
        {
            "speaker": "如玉",
            "text": "安同，明天我們沒課，你想去哪裡？"
        },
        {
            "speaker": "安同",
            "text": "我要跟同學去參觀故宮博物院。"
        },
        {
            "speaker": "如玉",
            "text": "聽說那裡有很多中國古代的東西。"
        },
        {
            "speaker": "安同",
            "text": "是啊。妳要跟我們去看看嗎？"
        },
        {
            "speaker": "如玉",
            "text": "好。怎麼去？"
        },
        {
            "speaker": "安同",
            "text": "我同學騎機車載我。妳可以坐公共汽車去。"
        },
        {
            "speaker": "如玉",
            "text": "我想坐捷運去。比較快。"
        },
        {
            "speaker": "安同",
            "text": "不行，到故宮沒有捷運。妳要不要坐計程車去？"
        },
        {
            "speaker": "如玉",
            "text": "太貴了！我坐公車。騎機車比坐公車快嗎？"
        },
        {
            "speaker": "安同",
            "text": "差不多。"
        }
    ],
    "lesson_number": 8
}
